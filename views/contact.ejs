                    <div class="card-body p-3 p-lg-5 text-center">
                        <h3 class="form-title">Contact Us</h3>
                        <form method="post" class="email-form" action="#">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <input type="text" name="name" class="form-control" placeholder="Your Name"
                                        required="">
