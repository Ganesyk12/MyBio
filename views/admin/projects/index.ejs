<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Project Management</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/centralize"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#!">Content Management</a></li>
                    <li class="breadcrumb-item"><a href="/centralize/projects">Projects</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>All Projects</h5>
                <div class="card-header-right">
                    <a href="/centralize/projects/create" class="btn btn-primary btn-sm">
                        <i class="feather icon-plus"></i> Add New Project
                    </a>
                </div>
            </div>
            <div class="card-body table-border-style">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <div class="form-group">
                            <input type="text" class="form-control" id="searchProject" placeholder="🔍 Search project name...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <select class="form-control" id="filterStatus">
                                <option value="">All Status</option>
                                <option value="A">Active</option>
                                <option value="N">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <select class="form-control" id="filterType">
                                <option value="">All Types</option>
                                <% if (typeof projects !== 'undefined' && projects.length > 0) { 
                                    const uniqueTypes = [...new Set(projects.map(p => p.ProjectType?.TypeName).filter(Boolean))];
                                    uniqueTypes.forEach(typeName => { %>
                                        <option value="<%= typeName %>"><%= typeName %></option>
                                    <% });
                                } %>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <select class="form-control" id="filterSkill">
                                <option value="">All Skills</option>
                                <% if (typeof projects !== 'undefined' && projects.length > 0) { 
                                    const allSkills = [];
                                    projects.forEach(p => {
                                        if (p.ProjectDetail) {
                                            p.ProjectDetail.forEach(d => {
                                                if (d.Skill && !allSkills.find(s => s.IdSkill === d.Skill.IdSkill)) {
                                                    allSkills.push(d.Skill);
                                                }
                                            });
                                        }
                                    });
                                    allSkills.forEach(skill => { %>
                                        <option value="<%= skill.SkillName %>"><%= skill.SkillName %></option>
                                    <% });
                                } %>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover" id="projectsTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Project Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Details</th>
                                <th>Date Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                                <% projects.forEach((project, index) => { 
                                    // Get all skill names for this project
                                    const projectSkills = [];
                                    if (project.ProjectDetail) {
                                        project.ProjectDetail.forEach(d => {
                                            if (d.Skill) {
                                                projectSkills.push(d.Skill.SkillName);
                                            }
                                        });
                                    }
                                    const skillData = projectSkills.length > 0 ? projectSkills.join(',') : 'No Skill';
                                %>
                                <tr data-name="<%= project.ProjectName.toLowerCase() %>" data-status="<%= project.Status %>" data-type="<%= project.ProjectType?.TypeName || '' %>" data-skills="<%= skillData.toLowerCase() %>">
                                    <td><%= index + 1 %></td>
                                    <td><%= project.ProjectName %></td>
                                    <td><label class="badge badge-light-primary"><%= project.ProjectType ? project.ProjectType.TypeName : 'N/A' %></label></td>
                                    <td>
                                        <% if (project.Status === 'N') { %>
                                            <label class="badge badge-light-danger">Inactive</label>
                                        <% } else { %>
                                            <label class="badge badge-light-success">Active</label>
                                        <% } %>
                                    </td>
                                    <td>
                                        <ul class="list-unstyled mb-0">
                                            <% if (project.ProjectDetail && project.ProjectDetail.length > 0) { %>
                                                <% project.ProjectDetail.forEach(detail => { %>
                                                    <li class="text-muted small">
                                                        <i class="feather icon-check m-r-5 text-success"></i>
                                                        <%= (detail.Description && detail.Description.length > 30) ? detail.Description.substring(0, 30) + '...' : (detail.Description || '-') %>
                                                    </li>
                                                <% }) %>
                                            <% } else { %>
                                                <li class="text-muted small">No details</li>
                                            <% } %>
                                        </ul>
                                    </td>
                                    <td><%= new Date(project.DateCreated).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                    <td>
                                        <a href="/centralize/projects/detail/<%= project.IdProject %>" class="btn btn-primary btn-sm" title="View Detail">
                                            <i class="feather icon-eye"></i>
                                        </a>
                                        <a href="/centralize/projects/edit/<%= project.IdProject %>" class="btn btn-info btn-sm" title="Edit">
                                            <i class="feather icon-edit"></i>
                                        </a>
                                        <form action="/centralize/projects/delete/<%= project.IdProject %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this project?');">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="feather icon-trash-2"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center">No projects found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchProject');
        const filterStatus = document.getElementById('filterStatus');
        const filterType = document.getElementById('filterType');
        const filterSkill = document.getElementById('filterSkill');
        const table = document.getElementById('projectsTable');
        const rows = table.querySelectorAll('tbody tr');

        function filterTable() {
            const searchTerm = searchInput.value.toLowerCase();
            const statusValue = filterStatus.value;
            const typeValue = filterType.value;
            const skillValue = filterSkill.value.toLowerCase();

            rows.forEach(row => {
                if (row.getAttribute('data-name') === undefined) return;

                const name = row.getAttribute('data-name');
                const status = row.getAttribute('data-status');
                const type = row.getAttribute('data-type');
                const skills = row.getAttribute('data-skills');

                const matchSearch = !searchTerm || name.includes(searchTerm);
                const matchStatus = !statusValue || status === statusValue;
                const matchType = !typeValue || type === typeValue;
                const matchSkill = !skillValue || skills.includes(skillValue) || (skillValue === 'no skill' && skills === 'no skill');

                if (matchSearch && matchStatus && matchType && matchSkill) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        searchInput.addEventListener('input', filterTable);
        filterStatus.addEventListener('change', filterTable);
        filterType.addEventListener('change', filterTable);
        filterSkill.addEventListener('change', filterTable);
    });
</script>


