<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Project Management</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/centralize"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="/centralize/projects">Projects</a></li>
                    <li class="breadcrumb-item"><a href="#!">Create Project</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>Add New Project</h5>
            </div>
            <div class="card-body">
                <form action="/centralize/projects/create" method="POST" enctype="multipart/form-data">
                    <div class="form-group row">
                        <label for="ProjectName" class="col-sm-2 col-form-label">Project Name</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="ProjectName" name="ProjectName" placeholder="e.g. E-Commerce Dashboard" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="IdType" class="col-sm-2 col-form-label">Project Type</label>
                        <div class="col-sm-10">
                            <select class="form-control" id="IdType" name="IdType" required>
                                <option value="" disabled selected>Select a project type</option>
                                <% types.forEach(type => { %>
                                    <option value="<%= type.IdType %>"><%= type.TypeName %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="Status" class="col-sm-2 col-form-label">Status</label>
                        <div class="col-sm-10">
                            <select class="form-control" id="Status" name="Status" required>
                                <option value="A" selected>Active</option>
                                <option value="N">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <hr>
                    <h6 class="mb-3">Initial Project Detail</h6>
                    
                    <div class="form-group row">
                        <label for="Description" class="col-sm-2 col-form-label">Description (Optional)</label>
                        <div class="col-sm-10">
                            <textarea class="form-control" id="Description" name="Description" rows="3" placeholder="Project description..."></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="FileImage" class="col-sm-2 col-form-label">Project Image (Optional)</label>
                        <div class="col-sm-10">
                            <input type="file" class="form-control-file" id="FileImage" name="FileImage" accept="image/*">
                            <small class="text-muted">Upload an image file (JPG, PNG, WEBP). It will be saved to /img/portfolio/</small>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="Link" class="col-sm-2 col-form-label">Link (Optional)</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="Link" name="Link" placeholder="https://github.com/my/project">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="IdSkill" class="col-sm-2 col-form-label">Related Skill (Optional)</label>
                        <div class="col-sm-10">
                            <select class="form-control" id="IdSkill" name="IdSkill">
                                <option value="">None / Select a skill</option>
                                <% skills.forEach(skill => { %>
                                    <option value="<%= skill.IdSkill %>"><%= skill.SkillName %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row mt-4">
                        <div class="col-sm-10">
                            <button type="submit" class="btn btn-primary">Create Project</button>
                            <a href="/centralize/projects" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
