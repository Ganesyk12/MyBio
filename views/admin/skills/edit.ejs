<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Skill Management</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/centralize"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="/centralize/skills">Skills</a></li>
                    <li class="breadcrumb-item"><a href="#!">Edit Skill</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>Edit Skill</h5>
            </div>
            <div class="card-body">
                <form action="/centralize/skills/edit/<%= skill.IdSkill %>" method="POST">
                    <div class="form-group row">
                        <label for="SkillName" class="col-sm-2 col-form-label">Skill Name</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="SkillName" name="SkillName" value="<%= skill.SkillName %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="Status" class="col-sm-2 col-form-label">Status</label>
                        <div class="col-sm-10">
                            <select class="form-control" id="Status" name="Status" required>
                                <option value="A" <%= skill.Status === 'A' ? 'selected' : '' %>>Active</option>
                                <option value="N" <%= skill.Status === 'N' ? 'selected' : '' %>>Inactive</option>
                            </select>
                        </div>
                    </div>
                    <!-- Added based on recent DB schema update -->
                    <div class="form-group row">
                        <label for="Icon" class="col-sm-2 col-form-label">Icon (Optional)</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="Icon" name="Icon" value="<%= skill.Icon || '' %>">
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-10">
                            <button type="submit" class="btn btn-primary">Update Skill</button>
                            <a href="/centralize/skills" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
