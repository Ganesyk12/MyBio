<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Skill Management</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/centralize"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#!">Content Management</a></li>
                    <li class="breadcrumb-item"><a href="/centralize/skills">Skills</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>All Skills</h5>
                <div class="card-header-right">
                    <a href="/centralize/skills/create" class="btn btn-primary btn-sm">
                        <i class="feather icon-plus"></i> Add New Skill
                    </a>
                </div>
            </div>
            <div class="card-body table-border-style">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Icon</th>
                                <th>Skill Name</th>
                                <th>Date Created</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof skills !== 'undefined' && skills.length > 0) { %>
                                <% skills.forEach((skill, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>
                                        <% if (skill.Icon) { %>
                                            <i class="<%= skill.Icon %> mr-2"></i> <%= skill.Icon %>
                                        <% } else { %>
                                            <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                    <td><%= skill.SkillName %></td>
                                    <td><%= new Date(skill.DateCreated).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                    <td>
                                        <% if (skill.Status === 'A') { %>
                                            <label class="badge badge-light-success">Active</label>
                                        <% } else { %>
                                            <label class="badge badge-light-danger">Inactive</label>
                                        <% } %>
                                    </td>
                                    <td>
                                        <a href="/centralize/skills/edit/<%= skill.IdSkill %>" class="btn btn-info btn-sm">
                                            <i class="feather icon-edit"></i>
                                        </a>
                                        <form action="/centralize/skills/delete/<%= skill.IdSkill %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this skill?');">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="feather icon-trash-2"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center">No skills found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


