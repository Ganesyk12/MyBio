<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Skill Management</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/centralize"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="/centralize/skills">Skills</a></li>
                    <li class="breadcrumb-item"><a href="#!">Create Skill</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>Add New Skill</h5>
            </div>
            <div class="card-body">
                <form action="/centralize/skills/create" method="POST">
                    <div class="form-group row">
                        <label for="SkillName" class="col-sm-2 col-form-label">Skill Name</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="SkillName" name="SkillName" placeholder="e.g. JavaScript" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="Status" class="col-sm-2 col-form-label">Status</label>
                        <div class="col-sm-10">
                            <select class="form-control" id="Status" name="Status" required>
                                <option value="A" selected>Active</option>
                                <option value="N">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <!-- Icon input based on your updated Prisma schema -->
                    <div class="form-group row">
                        <label for="Icon" class="col-sm-2 col-form-label">Icon (Optional)</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="Icon" name="Icon" placeholder="e.g. fa-brands fa-js">
                        </div>
                    </div>
                    <div class="form-group row mt-4">
                        <div class="col-sm-10">
                            <button type="submit" class="btn btn-primary">Create Skill</button>
                            <a href="/centralize/skills" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
