<section id="about" class="about section light-background">

    <div class="container section-title" data-aos="fade-down">
        <h2>About Me</h2>
        <div class="title-shape">
            <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor"
                    stroke-width="2"></path>
            </svg>
        </div>

    </div>
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row align-items-center">
            <div class="col-lg-5 position-relative" data-aos="fade-right" data-aos-delay="200">
                <div class="about-image">
                    <img src="/img/profile/profile.webp" alt="Profile Image" class="img-fluid rounded-5"
                        style="max-width: 75%; display: block; margin: 0 auto;">
                </div>
            </div>
            <div class="col-lg-7" data-aos="fade-left" data-aos-delay="300">
                <div class="about-content">
                    <h2 style="text-align: center;">IT Developer &amp; Web Programmer</h2>
                    <p class="lead-4" style="text-align: justify;">
                        I'm an Informatics Engineer with two years of experience in software development and project
                        management within the retail and manufacturing sectors. Known for being diligent, responsible,
                        and collaborative, I actively build personal projects and have completed several application
                        projects as part of that initiative to enhance my skills and professional growth.</p>
                    <div class="personal-info glass p-4 mt-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="info-item d-flex align-items-start">
                                    <div class="info-icon me-3">
                                        <i class="bi bi-person text-accent"></i>
                                    </div>
                                    <div>
                                        <span class="label">Name</span>
                                        <span class="value d-block">Ganes Yudha Kusuma</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item d-flex align-items-start">
                                    <div class="info-icon me-3">
                                        <i class="bi bi-linkedin text-accent"></i>
                                    </div>
                                    <div>
                                        <span class="label">LinkedIn</span>
                                        <span class="value d-block"><a
                                                href="https://www.linkedin.com/in/ganesyudhakusuma" target="_blank"
                                                class="text-accent">LinkedIn Profile</a></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item d-flex align-items-start">
                                    <div class="info-icon me-3">
                                        <i class="bi bi-calendar-event text-accent"></i>
                                    </div>
                                    <div>
                                        <span class="label">Birthday</span>
                                        <span class="value d-block">October 12, 2002</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item d-flex align-items-start">
                                    <div class="info-icon me-3">
                                        <i class="bi bi-envelope text-accent"></i>
                                    </div>
                                    <div>
                                        <span class="label">Email</span>
                                        <span class="value d-block">ganesyudhakusuma@gmail.com</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row align-items-center mt-5">
                        <div class="col-12">
                            <h4 class="text-accent text-center mb-4"
                                style="font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">Professional
                                Skills</h4>
                        </div>
                    </div>
                    <div class="row g-3 justify-content-center">
                        <% if (skills && skills.length> 0) {
                            const iconMap = {
                            '.net': 'bi-microsoft',
                            'c#': 'bi-hash',
                            'codeigniter': 'bi-fire',
                            'laravel': 'bi-box-seam',
                            'express js': 'bi-hdd-network',
                            'node js': 'bi-node-plus',
                            'javascript': 'bi-filetype-js',
                            'html': 'bi-filetype-html',
                            'css': 'bi-filetype-css',
                            'bootstrap': 'bi-bootstrap',
                            'git': 'bi-git',
                            'sql server': 'bi-database-fill-gear',
                            'mysql': 'bi-database-fill',
                            'php': 'bi-filetype-php'
                            };

                            skills.forEach(function(skill) {
                            const skillNameLower = (skill.SkillName || "").toLowerCase();
                            let iconClass = 'bi bi-check2-circle';

                            if (skill.Icon) {
                                iconClass = skill.Icon;
                            } else {
                                let fallback = 'bi-check2-circle';
                                if (skillNameLower.includes('database')) {
                                    fallback = 'bi-database-fill';
                                } else if (skillNameLower.includes('git')) {
                                    fallback = 'bi-github';
                                } else if (iconMap[skillNameLower]) {
                                    fallback = iconMap[skillNameLower];
                                }
                                iconClass = 'bi ' + fallback;
                            }
                            %>
                            <div class="col-6 col-sm-4 col-md-4 col-lg-3">
                                <div class="skill-badge-pro">
                                    <i class="<%= iconClass %>"></i>
                                    <span class="skill-name">
                                        <%= skill.SkillName %>
                                    </span>
                                </div>
                            </div>
                            <% }); } else { %>
                                <div class="col-12 text-center">
                                    <p class="text-muted">No skills available.</p>
                                </div>
                                <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>