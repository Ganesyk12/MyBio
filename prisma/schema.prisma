generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmailReceive {
  IdMail Int @id @default(autoincrement())
  Name String
  Email String
  Subject String
  Message String
  Status String?
  DateCreate DateTime @default(now())  
}

model Project {
  IdProject Int @id @default(autoincrement())
  IdType Int
  ProjectName String
  DateCreated DateTime @default(now())
  Status String?
  ProjectDetail ProjectDetail[]

  ProjectType ProjectType @relation(fields: [IdType], references: [IdType])
}

model ProjectType {
  IdType Int @id @default(autoincrement())
  TypeName String

  Project Project[]
}

model ProjectDetail {
  IdProjectDetail Int @id @default(autoincrement())
  IdProject Int
  IdSkill Int
  Description String
  FilePath String
  Link String?
  DateCreated DateTime @default(now())

  Project Project @relation(fields: [IdProject], references: [IdProject])
  Skill Skill @relation(fields: [IdSkill], references: [IdSkill])
}

model Skill {
  IdSkill Int @id @default(autoincrement())
  SkillName String
  DateCreated DateTime @default(now())
  Status String?
  ProjectDetail ProjectDetail[]
  Icon String?
}

model UserLogin {
  IdUserLogin Int @id @default(autoincrement())
  UserName String @unique
  Password String
  CreatedBy String? @default("SYSTEM")
  ModifiedBy String? @default("SYSTEM")
  DateCreated DateTime @default(now())
  DateModified DateTime?
  Status String? @default("A")
}

model SmtpEmail {
  IdSmtp       Int       @id @default(autoincrement())
  Host         String    @db.VarChar(100)
  Port         Int
  EnableSSL    Boolean
  SenderName   String    @db.VarChar(100)
  SenderEmail  String    @db.VarChar(100)
  Username     String    @db.VarChar(100)
  Password     String    @db.VarChar(255)
  IsActive     Boolean
  Status       String?   @db.VarChar(255)
  DateCreated  DateTime? @default(now()) @db.Timestamp(0)
  DateModified DateTime? @updatedAt @db.Timestamp(0)
  UserCreated  String?   @db.VarChar(255)
  UserModified String?   @db.VarChar(255)

  @@map("SmtpEmails")
}